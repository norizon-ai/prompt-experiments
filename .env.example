# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API key (required for gpt-4o testing)
OPENAI_API_KEY=sk-...

# Default model (used when target_model is not specified)
MODEL_NAME=gpt-4o

# Temperature (default: 0.2)
TEMPERATURE=0.2

# Max tokens (default: 4000)
MAX_TOKENS=4000

# --- Model-specific notes ---
# gpt-4o: Use OPENAI_API_KEY above. Model name: "gpt-4o"
# mistral-25b: Requires a separate endpoint (e.g. local vLLM, IONOS, or Mistral API).
#   Set OPENAI_API_KEY to your Mistral/vLLM key, MODEL_NAME to "mistral-25b",
#   and if needed, override the base URL in api_client.py.
