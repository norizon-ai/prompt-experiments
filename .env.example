# Copy this file to .env and fill in your values
# cp .env.example .env

# === OpenAI (for gpt-4o testing) ===
OPENAI_API_KEY=sk-...

# === Mistral (for mistral-25b testing) ===
MISTRAL_API_KEY=...

# Default model (used when target_model is not specified)
MODEL_NAME=gpt-4o

# Temperature (default: 0.2)
TEMPERATURE=0.2

# Max tokens (default: 4000)
MAX_TOKENS=4000
